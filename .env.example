# LLM Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Database (PostgreSQL or SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/analytics
# For local dev/testing use SQLite:
# DATABASE_URL=sqlite:///./dev.db

# LLM Model (e.g. claude-opus-4-6, gpt-4o, gpt-4o-mini)
LLM_MODEL=claude-opus-4-6

# Token limits
MAX_TOKENS_SQL=1024
MAX_TOKENS_SUMMARY=512

# Query limits
MAX_ROWS=10000
